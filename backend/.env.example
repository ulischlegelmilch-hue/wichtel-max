# Umgebungsvariablen fürs Backend (lokal: Datei nach ".env" kopieren; in der
# Cloud im Hoster-Dashboard eintragen). Alle sind optional – ohne sie läuft
# der lokale Standard (MQTT an, Port 8080).

# MQTT-Broker (nur für die ältere MQTT-Firmware). In der Cloud AUS lassen.
ENABLE_MQTT=0

# Wo state.json gespeichert wird. In der Cloud auf ein gemountetes Volume
# zeigen lassen, sonst gehen Daten beim Neustart verloren.
STATE_DIR=/data

# HTTP-Port. Wird in der Cloud automatisch vom Hoster gesetzt – NICHT anfassen.
# PORT=8080

# Geräte-Kennung (ergibt die MQTT-Topics wichtel/<id>/...). Standard: max
DEVICE_ID=max
